# 🔄 gitstat: Git repository quantum state analysis
gitstat() {
    local branch
    local repo
    local staged
    local modified
    local untracked
    local ahead
    local behind

    if ! command -v git &>/dev/null; then
        echo -e "\033[1;31m❌ Git does not exist in this dimensional plane\033[0m"
        return 1
    fi

    if ! git rev-parse --is-inside-work-tree &>/dev/null; then
        echo -e "\033[1;33m⚠️ Current location is not within a git reality field\033[0m"
        return 1
    fi

    echo -e "\033[1;34m🔍 Analyzing quantum git state...\033[0m"

    branch=$(git branch --show-current)
    repo=$(basename -s .git "$(git config --get remote.origin.url 2>/dev/null || echo "local-reality")")

    echo -e "\033[1;36m╒═════════════════════ GIT QUANTUM STATE ════════════════════╕\033[0m"
    echo -e "\033[1;36m│\033[0m \033[1;35mRepository:\033[0m ${repo}"
    echo -e "\033[1;36m│\033[0m \033[1;35mBranch:\033[0m ${branch}"

    # Changes
    staged=$(git diff --staged --name-only | wc -l)
    modified=$(git diff --name-only | wc -l)
    untracked=$(git ls-files --others --exclude-standard | wc -l)

    echo -e "\033[1;36m│\033[0m \033[1;33mStaged Changes:\033[0m ${staged}"
    echo -e "\033[1;36m│\033[0m \033[1;31mUnstaged Changes:\033[0m ${modified}"
    echo -e "\033[1;36m│\033[0m \033[1;34mUntracked Files:\033[0m ${untracked}"

    # Recent commits
    echo -e "\033[1;36m│\033[0m \033[1;35mRecent Reality Transitions:\033[0m"
    git log --oneline -n 5 | awk '{printf "\033[1;36m│\033[0m   \033[1;33m%s\033[0m \033[1;37m%s\033[0m\n", $1, substr($0, index($0, $2))}'

    # Remote status if available
    if git config --get remote.origin.url &>/dev/null; then
        ahead=$(git rev-list --count @{u}.. 2>/dev/null || echo 0)
        behind=$(git rev-list --count ..@{u} 2>/dev/null || echo 0)

        echo -e "\033[1;36m│\033[0m \033[1;32mAhead of Reality Stream:\033[0m ${ahead} commits"
        echo -e "\033[1;36m│\033[0m \033[1;31mBehind Reality Stream:\033[0m ${behind} commits"
    fi

    echo -e "\033[1;36m╘═════════════════════════════════════════════════════════════╛\033[0m"
}

