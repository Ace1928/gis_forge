# 📶 netspeed: Network throughput visualization
netspeed() {
    local interface
    local path
    local old_rx
    local old_tx
    local new_rx
    local new_tx
    local rx_rate
    local tx_rate
    local rx_bars
    local tx_bars
    local rx_pad
    local tx_pad

    interface="${1:-$(ip route | awk '/default/ {print $5; exit}')}"

    if [ -z "$interface" ]; then
        echo -e "\033[1;31m❌ No network interface found in this reality plane\033[0m"
        return 1
    fi

    path="/sys/class/net/$interface/statistics"

    if [ ! -d "$path" ]; then
        echo -e "\033[1;31m❌ Interface '$interface' does not exist in the current dimension\033[0m"
        return 1
    fi

    echo -e "\033[1;34m📶 Quantifying information flow on $interface...\033[0m"
    echo -e "\033[1;33m⚡ Monitoring active. Press Ctrl+C to collapse the wavefunction.\033[0m"

    old_rx=$(cat "$path/rx_bytes")
    old_tx=$(cat "$path/tx_bytes")

    echo -e "\033[1;36m╒══════════════════════ QUANTUM THROUGHPUT ═══════════════════════╕\033[0m"

    while true; do
        sleep 1
        new_rx=$(cat "$path/rx_bytes")
        new_tx=$(cat "$path/tx_bytes")

        rx_rate=$(( (new_rx - old_rx) / 1024 ))
        tx_rate=$(( (new_tx - old_tx) / 1024 ))

        # Visual bandwidth representation
        rx_bars=$(printf "█%.0s" $(seq 1 $(( rx_rate / 50 + 1 )) ))
        tx_bars=$(printf "█%.0s" $(seq 1 $(( tx_rate / 50 + 1 )) ))

        # Truncate if too long
        rx_bars="${rx_bars:0:20}"
        tx_bars="${tx_bars:0:20}"

        # Pad to consistent length
        rx_pad=$(printf "%-20s" "$rx_bars")
        tx_pad=$(printf "%-20s" "$tx_bars")

        echo -e "\r\033[K\033[1;36m│\033[0m \033[1;32m⬇️ $rx_rate KB/s $rx_pad\033[0m | \033[1;31m⬆️ $tx_rate KB/s $tx_pad\033[0m"

        old_rx=$new_rx
        old_tx=$new_tx
    done
}

