# Define dynamic identity construction algorithm
__construct_prompt() {
    # Calculate execution status - failures are just data points
    local last_exit_code=$?
    local exit_status=""
    if [ $last_exit_code -ne 0 ]; then
        exit_status="\[\033[1;31m\]✗ $last_exit_code\[\033[00m\] "
    else
        exit_status="\[\033[1;32m\]✓\[\033[00m\] "
    fi

    # Version control context integration
    local git_branch=""
    local git_status=""
    if command -v git >/dev/null 2>&1; then
        # Detect branch presence and state
        if git rev-parse --is-inside-work-tree &>/dev/null; then
            git_branch=$(git symbolic-ref --short HEAD 2>/dev/null || git describe --tags --always 2>/dev/null)
            local git_dirty=$(git status --porcelain 2>/dev/null | wc -l)
            if [ "$git_dirty" -gt 0 ]; then
                git_status="\[\033[0;33m\]⚡" # Changes detected
            else
                git_status="\[\033[0;32m\]✓" # Clean state
            fi
            git_branch="\[\033[0;36m\]($git_branch)$git_status\[\033[00m\] "
        fi
    fi

    # System load awareness - cognitive load monitoring
    local load=""
    if [ -r /proc/loadavg ]; then
        load=$(awk '{print $1}' /proc/loadavg)
        load_color="\[\033[0;32m\]" # Default to green
        if (( $(echo "$load > 1.0" | bc -l) )); then
            load_color="\[\033[0;33m\]" # Yellow for medium load
        fi
        if (( $(echo "$load > 2.0" | bc -l) )); then
            load_color="\[\033[0;31m\]" # Red for high load
        fi
        load=" ${load_color}⏱️ $load\[\033[00m\]"
    fi

    # Battery awareness - energy field monitoring
    local battery=""
    if command -v acpi &>/dev/null; then
        local bat_percent=$(acpi -b | grep -P -o '[0-9]+(?=%)' | head -1)
        if [ -n "$bat_percent" ]; then
            battery_color="\[\033[0;32m\]" # Default green
            battery_icon="🔋"
            if [ "$bat_percent" -lt 50 ]; then
                battery_color="\[\033[0;33m\]" # Yellow for medium
            fi
            if [ "$bat_percent" -lt 20 ]; then
                battery_color="\[\033[0;31m\]" # Red for low
                battery_icon="⚡"
            fi
            battery=" ${battery_color}$battery_icon $bat_percent%\[\033[00m\]"
        fi
    fi

    # Recursive prompt structure - each element builds upon the last
    PS1="${debian_chroot:+($debian_chroot)}"
    PS1+="\[\033[1;34m\]⏰ \t\[\033[00m\]" # Temporal context
    PS1+="$exit_status"                    # Execution state
    PS1+="\[\033[01;32m\]👤 \u@\h\[\033[00m\]:" # Identity marker
    PS1+="\[\033[01;34m\]📂 \w\[\033[00m\] "    # Spatial location
    PS1+="$git_branch"                     # Version control context
    PS1+="$load"                          # System load
    PS1+="$battery"                       # Power status
    PS1+="\n\[\033[01;35m\]λ\[\033[00m\] "  # Command entry point - second line for clarity
}

