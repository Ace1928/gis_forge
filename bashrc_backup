    echo -e "\033[1;36m│\033[0m \033[1;33m....\033[0m - Move up three directory levels"
    echo -e "\033[1;36m│\033[0m \033[1;33m.....\033[0m - Move up four directory levels"
    echo -e "\033[1;36m│\033[0m \033[1;33m-\033[0m - Return to previous directory"
    echo -e "\033[1;36m│\033[0m \033[1;33mcd.\033[0m - Resolve and navigate to true path"
    echo -e "\033[1;36m│\033[0m \033[1;33mcg\033[0m - Navigate to git repository root"
    echo -e "\033[1;36m╘═════════════════════════════════════════════════════════════════════╛\033[0m"

    # Display a random Eidosian usage tip
    local tips=(
        "Use Tab completion to accelerate command entry velocity."
        "Chain commands with && for conditional execution sequences."
        "Redirect outputs with > (overwrite) or >> (append) for information persistence."
        "The history command reveals your past self's thought patterns."
        "Use Ctrl+R for recursive history search - faster than scrolling through time."
        "Command substitution $(...) integrates command outputs into your execution flow."
        "Combine netspeed and syshealth to diagnose performance quantum entanglements."
        "The note function builds your second brain - an external thought repository."
        "⚡ All functions include error handling - your terminal is designed to fail gracefully."
    )
    local selected_tip=${tips[$RANDOM % ${#tips[@]}]}

    echo
    echo -e "\033[1;35m💡 TIP: ${selected_tip}\033[0m"
    echo
}

