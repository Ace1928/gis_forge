# Dependency installation function - recursive self-improvement
__install_dependency() {
    local pkg=$1
    local cmd=$2
    if ! command -v "$cmd" &>/dev/null; then
        echo -e "\033[1;33m⚠️  Missing dependency: $pkg\033[0m"
        if command -v apt &>/dev/null; then
            echo -e "\033[1;34m🔄 Installing via apt...\033[0m"
            sudo apt install -y "$pkg" || echo -e "\033[1;31m❌ Installation failed\033[0m"
        elif command -v yum &>/dev/null; then
            echo -e "\033[1;34m🔄 Installing via yum...\033[0m"
            sudo yum install -y "$pkg" || echo -e "\033[1;31m❌ Installation failed\033[0m"
        elif command -v brew &>/dev/null; then
            echo -e "\033[1;34m🔄 Installing via brew...\033[0m"
            brew install "$pkg" || echo -e "\033[1;31m❌ Installation failed\033[0m"
        else
            echo -e "\033[1;31m❌ No supported package manager found\033[0m"
            return 1
        fi
        echo -e "\033[1;32m✅ $pkg installed successfully\033[0m"
    fi
    return 0
}

