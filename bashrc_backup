# 📦 extract: Universal decompression protocol - knowledge liberation system
extract() {
    local file="${1:?$(echo -e "\033[1;33m📦 Usage: extract <file>\033[0m" >&2 && return 1)}"
    local filename

    if [ ! -f "$file" ]; then
        echo -e "\033[1;31m❌ Error: '$file' does not exist in this reality\033[0m"
        return 1
    fi

    filename=$(basename "$file")
    echo -e "\033[1;34m🔄 Extracting compressed knowledge from $filename...\033[0m"

    case "$file" in
        *.tar.bz2)   tar xjf "$file"     ;;
        *.tar.gz)    tar xzf "$file"     ;;
        *.bz2)       bunzip2 "$file"     ;;
        *.rar)       unrar x "$file"     ;;
        *.gz)        gunzip "$file"      ;;
        *.tar)       tar xf "$file"      ;;
        *.tbz2)      tar xjf "$file"     ;;
        *.tgz)       tar xzf "$file"     ;;
        *.zip)       unzip "$file"       ;;
        *.Z)         uncompress "$file"  ;;
        *.7z)        7z x "$file"        ;;
        *)           echo -e "\033[1;31m❌ Error: '$filename' contains knowledge in an unknown format\033[0m"
                     return 1            ;;
    esac

    echo -e "\033[1;32m✅ Knowledge liberation complete: $filename\033[0m"
}

